# Cursor Usage — Session tokens for live API (copy to .env, never commit)
#
# DevTools → Application → Cookies → https://cursor.com → WorkosCursorSessionToken
#
# User IDs must match config/users.json. Env key: CURSOR_SESSION_TOKEN_<ID uppercase>
CURSOR_SESSION_TOKEN_PRIMARY=
CURSOR_SESSION_TOKEN_SECONDARY=

# Legacy names (optional if your users.json still uses info/slope)
# CURSOR_SESSION_TOKEN_INFO=
# CURSOR_SESSION_TOKEN_SLOPE=

# Optional
CURSOR_WEB_HOST=127.0.0.1
CURSOR_WEB_PORT=8060

# Optional: auto-marker hooks (see scripts/setup-marker-hooks.ps1)
# CURSOR_MARKER_DEFAULT_USER=primary
# CURSOR_MARKER_API_BASE=http://127.0.0.1:8060
